{
	"name": "ICS-test-website",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt",
		"fmt:check": "oxfmt --check",
		"test:unit": "playwright install chromium && vitest",
		"test": "pnpm run test:unit -- --run",
		"test:watch": "pnpm run test:unit -- --watch",
		"test:coverage": "playwright install chromium && vitest run --coverage"
	},
	"dependencies": {
		"@lucide/svelte": "^0.563.1",
		"@vercel/analytics": "^1.6.1",
		"@vercel/speed-insights": "^1.3.1",
		"lucide-svelte": "^0.563.0",
		"super-sitemap": "^1.0.12"
	},
	"devDependencies": {
		"@skeletonlabs/skeleton": "^4.15.2",
		"@skeletonlabs/skeleton-svelte": "^4.15.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.1",
		"@types/node": "^20.19.43",
		"@vitest/browser-playwright": "^4.1.9",
		"@vitest/coverage-v8": "^4.1.9",
		"oxfmt": "^0.56.0",
		"oxlint": "^1.71.0",
		"playwright": "^1.61.1",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tailwindcss": "^4.3.1",
		"typescript": "^5.9.3",
		"vite": "^7.3.6",
		"vitest": "^4.1.9",
		"vitest-browser-svelte": "^2.1.1"
	},
	"packageManager": "pnpm@10.34.1",
	"pnpm": {
		"ignoredBuiltDependencies": [
			"esbuild"
		]
	}
}
